APP_ENV=development
APP_DEBUG=true
API_KEY=your-api-key-here

# Legacy Database
LEGACY_DB_DSN=mysql:host=legacy-db;dbname=legacy_erp
LEGACY_DB_USER=root
LEGACY_DB_PASS=root

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TIMEOUT=30

# Cache
CACHE_DRIVER=redis
REDIS_HOST=redis
REDIS_PORT=6379

# Logging
LOG_LEVEL=debug
